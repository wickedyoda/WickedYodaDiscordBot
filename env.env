# Required bot token
DISCORD_TOKEN=your_discord_bot_token_here

# Guild targeting
# Optional legacy single-guild default:
GUILD_ID=123456789012345678
# Optional multi-guild allowlist (comma-separated guild IDs):
MANAGED_GUILD_IDS=
# Optional global bot action log channel fallback (per-guild settings can override):
Bot_Log_Channel=123456789012345678

# Web admin listener
WEB_ENABLED=true
WEB_BIND_HOST=0.0.0.0
WEB_PORT=8081
WEB_TLS_ENABLED=true
# Optional custom cert/key pair. If both are empty and WEB_TLS_ENABLED=true, adhoc self-signed TLS is used.
WEB_TLS_CERT_FILE=
WEB_TLS_KEY_FILE=

# Discord behavior
ENABLE_MEMBERS_INTENT=false
COMMAND_RESPONSES_EPHEMERAL=false

# Random puppy command
PUPPY_IMAGE_API_URL=https://dog.ceo/api/breeds/image/random
PUPPY_IMAGE_TIMEOUT_SECONDS=8

# URL shortener integration
SHORTENER_ENABLED=true
SHORTENER_BASE_URL=https://l.twy4.us
SHORTENER_TIMEOUT_SECONDS=8

# YouTube notifications
YOUTUBE_NOTIFY_ENABLED=true
YOUTUBE_POLL_INTERVAL_SECONDS=300
YOUTUBE_REQUEST_TIMEOUT_SECONDS=12

# Uptime status integration
UPTIME_STATUS_ENABLED=true
UPTIME_STATUS_PAGE_URL=https://randy.wickedyoda.com/status/everything
UPTIME_STATUS_TIMEOUT_SECONDS=8

# Web auth/session
WEB_ADMIN_DEFAULT_USERNAME=admin@example.com
WEB_ADMIN_DEFAULT_PASSWORD=ChangeMe123!
# Optional alternative to WEB_ADMIN_DEFAULT_PASSWORD:
# WEB_ADMIN_DEFAULT_PASSWORD_HASH=pbkdf2:sha256:600000$...$...
WEB_ADMIN_SESSION_SECRET=replace_this_with_a_random_secret
WEB_SESSION_COOKIE_SECURE=false
WEB_SESSION_COOKIE_SAMESITE=Lax
WEB_SESSION_TIMEOUT_MINUTES=60

# Web hardening and controls
WEB_ENFORCE_CSRF=true
WEB_ENFORCE_SAME_ORIGIN_POSTS=true
WEB_AVATAR_MAX_UPLOAD_BYTES=2097152
WEB_RESTART_ENABLED=false

# Paths/storage
DATA_DIR=/app/data
# Optional explicit SQLite file path:
# ACTION_DB_PATH=/app/data/mod_actions.db
# Optional explicit log directory:
# LOG_DIR=/app/data
# Optional env file path for web settings editor:
WEB_ENV_FILE=./env.env
# Optional external wiki URL button in web GUI:
WEB_GITHUB_WIKI_URL=

# Logging levels
LOG_LEVEL=INFO
CONTAINER_LOG_LEVEL=WARNING
DISCORD_LOG_LEVEL=WARNING
